							"});",
							"",
							"var html = pm.response.text();",
							"",
							"// ── 1. Extract window.INITIAL_STATE ──────────────────────────────────────────",
							"function extractInitialState(h) {",
							"    var marker = 'window.INITIAL_STATE = ';",
							"    var startIdx = h.indexOf(marker);",
							"    if (startIdx === -1) return null;",
							"    var jsonStart = startIdx + marker.length;",
							"    if (h[jsonStart] !== '{') return null;",
							"    var depth = 0, inString = false, escape = false;",
							"    for (var i = jsonStart; i < h.length; i++) {",
							"        var ch = h[i];",
							"        if (escape)          { escape = false; continue; }",
							"        if (ch === '\\\\' && inString) { escape = true; continue; }",
							"        if (ch === '\"')      { inString = !inString; continue; }",
							"        if (inString)        { continue; }",
							"        if (ch === '{')      { depth++; }",
							"        else if (ch === '}') { depth--; if (depth === 0) return h.slice(jsonStart, i + 1); }",
							"    }",
							"    return null;",
							"}",
							"",
							"// ── 2. Token-level JS sanitizer ───────────────────────────────────────────────",
							"function sanitizeJS(src) {",
							"    var out = '', i = 0, len = src.length;",
							"    while (i < len) {",
							"        var ch = src[i];",
							"        if (ch === '\"') {",
							"            out += ch; i++;",
							"            while (i < len) {",
							"                var c = src[i]; out += c; i++;",
							"                if (c === '\\\\') { if (i < len) { out += src[i]; i++; } continue; }",
							"                if (c === '\"') break;",
							"            }",
							"            continue;",
							"        }",
							"        if (/[a-zA-Z_$]/.test(ch)) {",
							"            var word = '';",
							"            while (i < len && /[a-zA-Z0-9_$]/.test(src[i])) { word += src[i]; i++; }",
							"            var j = i;",
							"            while (j < len && /\\s/.test(src[j])) j++;",
							"            if (src[j] === ':') {",
							"                out += '\"' + word + '\"';",
							"            } else {",
							"                if (word === 'undefined' || word === 'NaN' || word === 'Infinity') out += 'null';",
							"                else if (word === 'true' || word === 'false' || word === 'null') out += word;",
							"                else out += 'null';",
							"            }",
							"            continue;",
							"        }",
							"        out += ch; i++;",
							"    }",
							"    return out;",
							"}",
							"",
							"// ── 3. Price resolver ─────────────────────────────────────────────────────────",
							"function resolvePrice(f) {",
							"    if (f == null) return 'N/A';",
							"    if (Array.isArray(f)) {",
							"        var edlp = f.filter(function(x){ return x && x.type === 'EDLP'; })[0];",
							"        var entry = edlp || f[0];",
							"        if (!entry) return 'N/A';",
							"        var v = entry.price != null ? entry.price : entry.value != null ? entry.value : entry.amount;",
							"        return v != null ? '$' + Number(v).toFixed(2) : 'N/A';",
							"    }",
							"    if (typeof f === 'number') return '$' + f.toFixed(2);",
							"    if (typeof f === 'object') {",
							"        var v2 = f.price != null ? f.price : f.value != null ? f.value : f.amount != null ? f.amount : f.low;",
							"        return v2 != null ? '$' + Number(v2).toFixed(2) : 'N/A';",
							"    }",
							"    if (typeof f === 'string' && f.trim()) return f;",
							"    return 'N/A';",
							"}",
							"",
							"// ── 4. Pack-size resolver ─────────────────────────────────────────────────────",
							"function resolvePackSize(p) {",
							"    return p.packageDescription || p.packageValue || p.packSize",
							"        || p.pack_size || p.unitDescription || p.unitSize",
							"        || p.size || p.volume || p.containerSize || 'N/A';",
							"}",
							"",
							"// ── 5. Parse INITIAL_STATE ────────────────────────────────────────────────────",
							"var rawStr = extractInitialState(html);",
							"pm.test(\"window.INITIAL_STATE found\", function () { pm.expect(rawStr).to.not.be.null; });",
							"",
							"var state = null;",
							"if (rawStr) {",
							"    try {",
							"        state = JSON.parse(rawStr);",
							"        console.log('Parse: raw JSON.parse OK');",
							"    } catch (e1) {",
							"        console.log('Raw parse failed:', e1.message.slice(0, 120));",
							"        try {",
							"            state = JSON.parse(sanitizeJS(rawStr));",
							"            console.log('Parse: sanitizer OK');",
							"        } catch (e2) {",
							"            console.log('Sanitized parse also failed:', e2.message.slice(0, 120));",
							"        }",
							"    }",
							"}",
							"",
							"// ── 6. Read pagination counters ───────────────────────────────────────────────",
							"var currentPage = parseInt(pm.collectionVariables.get(\"scrape_page\")) || 1;",
							"var totalPages  = parseInt(pm.collectionVariables.get(\"scrape_totalPages\")) || 0;",
							"",
							"// ── 7. Extract products ───────────────────────────────────────────────────────",
							"var pageProducts = [];",
							"",
							"if (state) {",
							"    var results    = state.search && state.search.results;",
							"    var pagination = results && results.pagination;",
							"",
							"    if (pagination && pagination.totalPages != null && totalPages === 0) {",
							"        totalPages = parseInt(pagination.totalPages);",
							"        pm.collectionVariables.set(\"scrape_totalPages\", String(totalPages));",
							"        console.log('Total pages: ' + totalPages + ' | Total results: ' + (pagination.totalResults || '?'));",
							"    }",
							"",
							"    var raw = (results && Array.isArray(results.products)) ? results.products : [];",
							"    console.log('Products on page ' + currentPage + ': ' + raw.length);",
							"",
							"    raw.forEach(function(p) {",
							"        if (!p) return;",
							"        pageProducts.push({",
							"            name:          p.name || p.displayName || p.title || 'N/A',",
							"            price:         resolvePrice(p.price || p.prices || p.pricing || p.priceInfo || p.listPrice || p.salePrice),",
							"            packSize:      resolvePackSize(p),",
							"            containerType: p.containerType || p.container || 'N/A',",
							"            rating:        p.customerAverageRating != null",
							"                               ? String(p.customerAverageRating) + ' (' + (p.customerReviewsCount || p.reviewCount || 0) + ' reviews)'",
							"                               : 'N/A',",
							"            sku:           String(p.skuId || p.id || p.productId || 'N/A'),",
							"            brand:         p.brand || p.brandName || 'N/A'",
							"        });",
							"    });",
							"}",
							"",
							"pm.test(\"Products extracted on this page\", function () {",
							"    pm.expect(pageProducts.length).to.be.above(0);",
							"});",
							"",
							"// ── 8. Accumulate rows in collection variable ─────────────────────────────────",
							"function escCsv(v) { return '\"' + String(v == null ? '' : v).replace(/\"/g, '\"\"') + '\"'; }",
							"",
							"if (currentPage === 1) {",
							"    pm.collectionVariables.set(\"scrape_csvData\", \"Name,Brand,Price,Pack Size,Container,Rating,SKU\\r\\n\");",
							"}",
							"",
							"var rowLines = '';",
							"pageProducts.forEach(function(p) {",
